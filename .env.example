# ══════════════════════════════════════════════════════════════════════════════
# spy-options-bridge — Render Environment Variables
# Copy to Render dashboard → Environment (or local .env for testing)
# ══════════════════════════════════════════════════════════════════════════════

# ── Execution ─────────────────────────────────────────────────────────────────
EXECUTION_MODE=sandbox
# sandbox    = cert dry-run endpoint (safe testing)
# production   = live cert orders

WEBHOOK_SECRET=replace-with-a-long-random-string
# Must match "webhookSecret" in TradingView alert JSON (header also supported)

# ── Tastytrade CERT Sandbox ───────────────────────────────────────────────────
TASTYTRADE_API_BASE_URL=https://api.cert.tastyworks.com
TASTYTRADE_SANDBOX_USERNAME=your_cert_sandbox_username
TASTYTRADE_SANDBOX_PASSWORD=your_cert_sandbox_password
TASTYTRADE_ACCOUNT_NUMBER=5WT00000

# ── DTE / Expiration filter ───────────────────────────────────────────────────
# 0dte   = today (ET)  |  weekly = nearest Friday on/after today
DEFAULT_DTE_FILTER=weekly

# ── Spread defaults ───────────────────────────────────────────────────────────
DEFAULT_UNDERLYING=SPY
DEFAULT_QUANTITY=1
DEFAULT_STRIKE_OFFSET_SHORT=-2
DEFAULT_STRIKE_OFFSET_LONG=-3
DEFAULT_LIMIT_CREDIT=0.50
MAX_QUANTITY=0

# ── Risk management ───────────────────────────────────────────────────────────
AUTO_TAKE_PROFIT=true
TAKE_PROFIT_PCT=0.50
AUTO_STOP_LOSS=true
STOP_LOSS_MULTIPLIER=2.0
DANGER_ZONE_PCT=0.01

# ── Notifications (optional — pick one or both) ───────────────────────────────
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
